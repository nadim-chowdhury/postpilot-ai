# ─────────────────────────────────────────────
# PostPilot AI — Environment Variables
# Copy this to .env.local and fill in your values
# ─────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Neon / Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/postpilot?sslmode=require

# Auth (NextAuth.js)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-32-char-string-here

# Meta / Facebook
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_GRAPH_API_VERSION=v24.0
META_CONFIG_ID=optional-login-configuration-id

# AI Content Generation (pick ONE provider — auto-detected by priority)
# Priority: Google Gemini → Anthropic Claude → OpenAI → Mock fallback

# 1. Google Gemini (recommended — free tier available via AI Studio)
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
# GEMINI_API_KEY=your-gemini-api-key  # Alternative env name (also works)

# 2. Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-api-key

# 3. OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_API_KEYS=sk-key1,sk-key2,sk-key3  # Optional comma-separated pool for key rotation

# Upstash (QStash + Redis)
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=your-signing-key
QSTASH_NEXT_SIGNING_KEY=your-next-signing-key
UPSTASH_REDIS_REST_URL=your-redis-url
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Security
ENCRYPTION_KEY=generate-a-32-byte-hex-key
CRON_SECRET=generate-a-random-string

# Monitoring
SENTRY_DSN=your-sentry-dsn
